+  // zentoo fix: brightness-suppress <ms> — let an external caller (e.g.,
+  // asahi-brightnessd, which mirrors ambient-light readings into hardware
+  // brightness on its own cadence) silence the OSD for a bounded window
+  // around its own brightness writes. Without this, every ALS update
+  // pops the brightness OSD into view even though the user never asked
+  // for a brightness change.
+  m_ipcService.registerHandler(
+      "brightness-suppress",
+      [this](const std::string& args) -> std::string {
+        const auto parts = noctalia::ipc::splitWords(args);
+        if (parts.size() != 1) {
+          return "error: brightness-suppress requires <milliseconds>\n";
+        }
+        int ms = 0;
+        const auto& token = parts[0];
+        const char* begin = token.data();
+        const char* end = begin + token.size();
+        const auto [ptr, ec] = std::from_chars(begin, end, ms);
+        if (ec != std::errc() || ptr != end || ms < 0 || ms > 60000) {
+          return "error: invalid duration (use milliseconds, 0..60000)\n";
+        }
+        m_brightnessOsd.suppressFor(std::chrono::milliseconds(ms));
+        return "ok\n";
+      },
+      "brightness-suppress <milliseconds>", "Suppress the brightness OSD for the given duration"
+  );
