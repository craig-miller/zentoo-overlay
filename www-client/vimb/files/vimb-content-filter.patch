+static void
+vimb_on_content_filter_loaded(GObject *source, GAsyncResult *res, gpointer user_data)
+{
+    int idx = GPOINTER_TO_INT(user_data);
+    WebKitUserContentFilterStore *store = WEBKIT_USER_CONTENT_FILTER_STORE(source);
+    GError *err = NULL;
+
+    vimb_content_filters[idx] =
+        webkit_user_content_filter_store_load_finish(store, res, &err);
+    vimb_content_filters_ready[idx] = TRUE;
+
+    if (!vimb_content_filters[idx]) {
+        g_warning("vimb: could not load content filter '%s': %s",
+                  vimb_content_filter_ids[idx],
+                  err ? err->message : "unknown error");
+        if (err) g_error_free(err);
+    }
+}
+
+static void
+vimb_init_content_filters(void)
+{
+    const char *store_path = VIMB_CONTENT_FILTER_STORE_PATH;
+    if (!store_path || !*store_path) {
+        return; /* explicitly disabled */
+    }
+    if (!g_file_test(store_path, G_FILE_TEST_IS_DIR)) {
+        g_message("vimb: no content-filter store at %s "
+                  "(install app-misc/vimb-blocklist to enable ad-blocking)",
+                  store_path);
+        return;
+    }
+
+    WebKitUserContentFilterStore *store =
+        webkit_user_content_filter_store_new(store_path);
+    for (int i = 0; i < VIMB_CONTENT_FILTER_COUNT; i++) {
+        webkit_user_content_filter_store_load(
+            store, vimb_content_filter_ids[i], NULL,
+            vimb_on_content_filter_loaded, GINT_TO_POINTER(i));
+    }
+
+    /* Spin the main context until every load completes (bytecode is
+     * cached on disk so this is milliseconds). Conservative timeout in
+     * case something's very wrong with the store. */
+    GMainContext *ctx = g_main_context_default();
+    gint64 deadline = g_get_monotonic_time() + 5 * G_TIME_SPAN_SECOND;
+    while (!(vimb_content_filters_ready[0]
+          && vimb_content_filters_ready[1]
+          && vimb_content_filters_ready[2])) {
+        if (g_get_monotonic_time() > deadline) {
+            g_warning("vimb: timed out loading content filters");
+            break;
+        }
+        g_main_context_iteration(ctx, TRUE);
+    }
+
+    g_object_unref(store);
+}
