+#define VIMB_CONTENT_FILTER_COUNT 3
+static const char *const vimb_content_filter_ids[VIMB_CONTENT_FILTER_COUNT] = {
+    "easylist", "easyprivacy", "cookies"
+};
+static WebKitUserContentFilter *vimb_content_filters[VIMB_CONTENT_FILTER_COUNT] = {NULL};
+static gboolean vimb_content_filters_ready[VIMB_CONTENT_FILTER_COUNT] = {FALSE};
