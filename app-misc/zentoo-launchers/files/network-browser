#!/bin/bash
# network-browser ‚ÄĒ discover LAN file shares via Avahi, mount one via gvfs.
# Shipped by app-misc/zentoo-launchers.
#
# Flow: avahi service picker ‚Üí host pick ‚Üí (SMB) gio-mount the host root to
# auth + enumerate, fzf share picker, gio-mount the picked share. (AFP /
# SFTP / WebDAV) bare-host URI, gio-mount it. Either way, the picked URI
# lands on the clipboard as a convenience. Each gio mount call prompts on
# the tty for credentials the first time and persists them via libsecret ‚Üí
# pass-secret-service ‚Üí pass.
#
# Note: gvfs's COMPAT_NETWORK schema and gvfs.yazi's custom schema don't
# cross-look-up. Creds saved here don't make a subsequent yazi `g a` mount
# of the same share silent (yazi will prompt once on its own). The Phase 2
# gvfs.yazi `discover` subcommand will fold both paths into one schema.

set -u

TYPES='_smb._tcp|_afpovertcp._tcp|_sftp-ssh._tcp|_webdav._tcp|_webdavs._tcp'

tmpfile=$(mktemp); trap 'rm -f "$tmpfile"; printf "\033[?25h"' EXIT

spin_until() {
    local pid=$1 label=$2
    local chars=(‚†č ‚†ô ‚†Ļ ‚†ł ‚†ľ ‚†ī ‚†¶ ‚†ß ‚†á ‚†Ź)
    local n=${#chars[@]} i=0
    printf '\033[?25l'
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r\033[36m%s\033[0m %s ' "${chars[i % n]}" "$label"
        i=$((i + 1))
        sleep 0.08
    done
    printf '\r\033[K\033[?25h'
}

url_encode() {
    local s=$1 i c
    for ((i=0; i<${#s}; i++)); do
        c="${s:i:1}"
        case "$c" in
            [a-zA-Z0-9._~-]) printf '%s' "$c" ;;
            *) printf '%%%02X' "'$c" ;;
        esac
    done
}

# True if any gvfs mount exists under "<scheme>://<host>". Matches both
# bare-host mounts (-> smb://host/) and share mounts (-> smb://host/share).
# Used to detect existing auth on the host so we can skip a redundant
# bare-host mount when yazi (or anyone) already mounted a share.
host_has_mount() {
    local scheme=$1 host=$2
    gio mount -l 2>/dev/null | grep -qiE "-> ${scheme}://${host}(/|\$)"
}

# True if this exact URI is mounted. End-anchored to a `/` or EOL so
# smb://host/craig doesn't match a query for smb://host/.
uri_is_mounted() {
    local uri=$1
    local needle="${uri%/}"
    gio mount -l 2>/dev/null | grep -qiE "(-> ${needle}\$|-> ${needle}/\$)"
}

(
    avahi-browse -art --parsable --no-db-lookup 2>/dev/null \
        | awk -F';' -v types="$TYPES" '
            function unescape(s,    out, i, c) {
                out = ""; i = 1
                while (i <= length(s)) {
                    c = substr(s, i, 1)
                    if (c == "\\" && i + 3 <= length(s) && substr(s, i+1, 3) ~ /^[0-9]{3}$/) {
                        out = out sprintf("%c", substr(s, i+1, 3) + 0)
                        i += 4
                    } else {
                        out = out c; i += 1
                    }
                }
                return out
            }
            $1 == "=" && $5 ~ types {
                proto = $5
                sub(/^_/, "", proto); sub(/\._tcp$/, "", proto)
                name = unescape($4)
                host = unescape($7)
                printf "%-32s  %-12s  %s\t%s\t%s\n", name, proto, host, proto, host
            }' \
        | sort -u > "$tmpfile"
) &
spin_until $! "Scanning LAN"
wait
services=$(<"$tmpfile")

if [[ -z "$services" ]]; then
    notify-send -a "Network Browser" "Network Browser" "No LAN file shares advertised"
    exit 0
fi

picked=$(printf '%s\n' "$services" \
    | fzf --delimiter=$'\t' --with-nth=1 \
          --prompt='LAN service: ' --height=40% --reverse) || exit 0

proto=$(printf '%s' "$picked" | cut -f2)
host=$(printf '%s' "$picked" | cut -f3)

case "$proto" in
    smb)
        # Authenticate to host so we can enumerate shares. If a mount under
        # the host already exists (yazi mounted a share earlier, etc.), we
        # already have the connection ‚ÄĒ skip the bare-host gio mount.
        if ! host_has_mount smb "$host"; then
            printf '\n\033[36m  Authenticating to\033[0m smb://%s/\n' "$host"
            gio mount "smb://$host/" || true
            if ! host_has_mount smb "$host"; then
                notify-send -a "Network Browser" "Network Browser" \
                    "Could not authenticate to smb://$host/"
                exit 1
            fi
        fi
        shares=$(gio list "smb://$host/" 2>/dev/null | awk '{print $1}') || shares=""
        if [[ -n "$shares" ]]; then
            share=$(printf '%s\n' "$shares" \
                | fzf --prompt="Share on $host: " --height=40% --reverse) || exit 0
            uri="smb://$host/$(url_encode "$share")"
        else
            uri="smb://$host/"
        fi
        ;;
    afpovertcp) uri="afp://$host/" ;;
    sftp-ssh)   uri="sftp://$host/" ;;
    webdav)     uri="dav://$host/" ;;
    webdavs)    uri="davs://$host/" ;;
    *)
        notify-send -a "Network Browser" "Network Browser" "Unknown protocol: $proto"
        exit 1
        ;;
esac

# Mount the picked URI. Idempotent: if it's already mounted, do nothing.
if ! uri_is_mounted "$uri"; then
    printf '\n\033[36m  Mounting\033[0m %s\n' "$uri"
    gio mount "$uri" || true
    if ! uri_is_mounted "$uri"; then
        notify-send -a "Network Browser" "Network Browser" "Mount failed for $uri"
        exit 1
    fi
fi

printf %s "$uri" | wl-copy
notify-send -a "Network Browser" "Network Browser" "Mounted: $uri"
