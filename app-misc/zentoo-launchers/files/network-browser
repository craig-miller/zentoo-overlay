#!/bin/bash
# network-browser — discover LAN file shares via Avahi, mount one via gvfs.
# Shipped by app-misc/zentoo-launchers.
#
# Flow: avahi service picker → host pick → (SMB) `gio list smb://host/` to
# enumerate shares (smb-browse prompts on tty if it needs auth), fzf share
# picker, `gio mount smb://host/share` to mount. (AFP / SFTP / WebDAV) bare-
# host URI, `gio mount` it. URI also lands on clipboard as a convenience.
#
# Cred storage: gio mount persists creds via libsecret → pass-secret-service
# → pass. gvfs's COMPAT_NETWORK schema and gvfs.yazi's custom schema don't
# cross-look-up, so creds saved here don't make a later yazi `g a` of the
# same share silent. Phase 2 of the gvfs-yazi-discover plan folds both into
# one schema.

set -u

# Defensive env: a foot terminal opened ad hoc sometimes loses
# DBUS_SESSION_BUS_ADDRESS, which makes notify-send try to autolaunch via
# X11. Point it at the canonical user-session socket if available.
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"
if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" && -S "$XDG_RUNTIME_DIR/bus" ]]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
fi

TYPES='_smb._tcp|_afpovertcp._tcp|_sftp-ssh._tcp|_webdav._tcp|_webdavs._tcp'

tmpfile=$(mktemp); trap 'rm -f "$tmpfile"; printf "\033[?25h"' EXIT

spin_until() {
    local pid=$1 label=$2
    local chars=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
    local n=${#chars[@]} i=0
    printf '\033[?25l'
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r\033[36m%s\033[0m %s ' "${chars[i % n]}" "$label"
        i=$((i + 1))
        sleep 0.08
    done
    printf '\r\033[K\033[?25h'
}

url_encode() {
    local s=$1 i c
    for ((i=0; i<${#s}; i++)); do
        c="${s:i:1}"
        case "$c" in
            [a-zA-Z0-9._~-]) printf '%s' "$c" ;;
            *) printf '%%%02X' "'$c" ;;
        esac
    done
}

# True if this exact URI is mounted. End-anchored so smb://host/share
# doesn't match a check for smb://host/. `--` keeps grep from parsing the
# leading `->` as a flag.
uri_is_mounted() {
    local uri=$1
    local needle="${uri%/}"
    gio mount -l 2>/dev/null | grep -qiE -- "(-> ${needle}$|-> ${needle}/$)"
}

(
    avahi-browse -art --parsable --no-db-lookup 2>/dev/null \
        | awk -F';' -v types="$TYPES" '
            function unescape(s,    out, i, c) {
                out = ""; i = 1
                while (i <= length(s)) {
                    c = substr(s, i, 1)
                    if (c == "\\" && i + 3 <= length(s) && substr(s, i+1, 3) ~ /^[0-9]{3}$/) {
                        out = out sprintf("%c", substr(s, i+1, 3) + 0)
                        i += 4
                    } else {
                        out = out c; i += 1
                    }
                }
                return out
            }
            $1 == "=" && $5 ~ types {
                proto = $5
                sub(/^_/, "", proto); sub(/\._tcp$/, "", proto)
                name = unescape($4)
                host = unescape($7)
                printf "%-32s  %-12s  %s\t%s\t%s\n", name, proto, host, proto, host
            }' \
        | sort -u > "$tmpfile"
) &
spin_until $! "Scanning LAN"
wait
services=$(<"$tmpfile")

if [[ -z "$services" ]]; then
    notify-send -a "Network Browser" "Network Browser" "No LAN file shares advertised"
    exit 0
fi

picked=$(printf '%s\n' "$services" \
    | fzf --delimiter=$'\t' --with-nth=1 \
          --prompt='LAN service: ' --height=40% --reverse) || exit 0

proto=$(printf '%s' "$picked" | cut -f2)
host=$(printf '%s' "$picked" | cut -f3)

case "$proto" in
    smb)
        # Enumerate shares via gvfsd-smb-browse. It prompts on the tty if
        # the server demands auth (macOS Tahoe blocks anon). Drop admin
        # shares ($-suffixed: IPC$, ADMIN$, c$) and any error lines.
        printf '\n\033[36m  Listing shares on\033[0m smb://%s/\n' "$host"
        shares=$(gio list "smb://$host/" 2>&1 \
                 | grep -vE -- '\$$|^$|^gio:|^Error|^Operation' || true)
        if [[ -z "$shares" ]]; then
            read -r -p "Share on $host (enumeration empty; type a share name): " share < /dev/tty || share=""
            [[ -z "$share" ]] && exit 0
            uri="smb://$host/$(url_encode "$share")"
        else
            share=$(printf '%s\n' "$shares" \
                | fzf --prompt="Share on $host: " --height=40% --reverse) || exit 0
            uri="smb://$host/$(url_encode "$share")"
        fi
        ;;
    afpovertcp) uri="afp://$host/" ;;
    sftp-ssh)   uri="sftp://$host/" ;;
    webdav)     uri="dav://$host/" ;;
    webdavs)    uri="davs://$host/" ;;
    *)
        notify-send -a "Network Browser" "Network Browser" "Unknown protocol: $proto"
        exit 1
        ;;
esac

# Mount the picked URI. Idempotent: if it's already mounted, do nothing.
if ! uri_is_mounted "$uri"; then
    printf '\n\033[36m  Mounting\033[0m %s\n' "$uri"
    gio mount "$uri" || true
    if ! uri_is_mounted "$uri"; then
        notify-send -a "Network Browser" "Network Browser" "Mount failed for $uri"
        exit 1
    fi
fi

printf %s "$uri" | wl-copy
notify-send -a "Network Browser" "Network Browser" "Mounted: $uri"
