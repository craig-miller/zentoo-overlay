#!/bin/bash
# network-browser вЂ” discover LAN file shares via Avahi, copy a mount URI to
# the Wayland clipboard. Shipped by app-misc/zentoo-launchers.
#
# Hand-off model: this launcher does discovery + clipboard ONLY. Paste the
# copied URI in yazi (g a) to mount; yazi + gvfs.yazi own auth (via the
# keyring vault в†’ pass-secret-service в†’ pass) and the persistent mount.
# See install-guide Ch.25 for the substrate rationale.

set -u

TYPES='_smb._tcp|_afpovertcp._tcp|_sftp-ssh._tcp|_webdav._tcp|_webdavs._tcp'

tmpfile=$(mktemp); trap 'rm -f "$tmpfile"; printf "\033[?25h"' EXIT

spin_until() {
    local pid=$1 label=$2
    local chars=(в ‹ в ™ в № в ё в ј в ґ в ¦ в § в ‡ в Џ)
    local n=${#chars[@]} i=0
    printf '\033[?25l'
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r\033[36m%s\033[0m %s ' "${chars[i % n]}" "$label"
        i=$((i + 1))
        sleep 0.08
    done
    printf '\r\033[K\033[?25h'
}

url_encode() {
    local s=$1 i c
    for ((i=0; i<${#s}; i++)); do
        c="${s:i:1}"
        case "$c" in
            [a-zA-Z0-9._~-]) printf '%s' "$c" ;;
            *) printf '%%%02X' "'$c" ;;
        esac
    done
}

(
    avahi-browse -art --parsable --no-db-lookup 2>/dev/null \
        | awk -F';' -v types="$TYPES" '
            function unescape(s,    out, i, c) {
                out = ""; i = 1
                while (i <= length(s)) {
                    c = substr(s, i, 1)
                    if (c == "\\" && i + 3 <= length(s) && substr(s, i+1, 3) ~ /^[0-9]{3}$/) {
                        out = out sprintf("%c", substr(s, i+1, 3) + 0)
                        i += 4
                    } else {
                        out = out c; i += 1
                    }
                }
                return out
            }
            $1 == "=" && $5 ~ types {
                proto = $5
                sub(/^_/, "", proto); sub(/\._tcp$/, "", proto)
                name = unescape($4)
                host = unescape($7)
                printf "%-32s  %-12s  %s\t%s\t%s\n", name, proto, host, proto, host
            }' \
        | sort -u > "$tmpfile"
) &
spin_until $! "Scanning LAN"
wait
services=$(<"$tmpfile")

if [[ -z "$services" ]]; then
    notify-send -a "Network Browser" "Network Browser" "No LAN file shares advertised"
    exit 0
fi

picked=$(printf '%s\n' "$services" \
    | fzf --delimiter=$'\t' --with-nth=1 \
          --prompt='LAN service: ' --height=40% --reverse) || exit 0

proto=$(printf '%s' "$picked" | cut -f2)
host=$(printf '%s' "$picked" | cut -f3)

case "$proto" in
    smb)
        read -r -p "Share on $host (Enter for host root): " share < /dev/tty || share=""
        if [[ -n "$share" ]]; then
            uri="smb://$host/$(url_encode "$share")"
        else
            uri="smb://$host/"
        fi
        ;;
    afpovertcp) uri="afp://$host/" ;;
    sftp-ssh)   uri="sftp://$host/" ;;
    webdav)     uri="dav://$host/" ;;
    webdavs)    uri="davs://$host/" ;;
    *)
        notify-send -a "Network Browser" "Network Browser" "Unknown protocol: $proto"
        exit 1
        ;;
esac

printf %s "$uri" | wl-copy
notify-send -a "Network Browser" "Network Browser" "Copied: $uri вЂ” paste in yazi (g a) to mount"
