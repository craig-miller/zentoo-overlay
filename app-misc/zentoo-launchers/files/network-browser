#!/bin/bash
# network-browser — discover LAN file shares via Avahi, pick a share, copy
# its URI to the Wayland clipboard. Shipped by app-misc/zentoo-launchers.
#
# Flow: avahi service picker → host pick → for SMB, gio-mount the host root
# (which tty-prompts for creds the first time and persists them via
# libsecret → pass-secret-service → pass) so we can `gio list` its shares →
# share picker → clipboard. Final mount of the picked share is yazi's job:
# paste the URI in `g a`. The launcher only discovers and translates.
#
# Note: gvfs and gvfs.yazi store creds under different libsecret schemas,
# so the host-root mount this script does does NOT make yazi's share mount
# silent — yazi will prompt once on its own, then be silent for subsequent
# mounts of the same share. This launcher's prompt + yazi's prompt are
# independent. (Phase 2 of the gvfs-yazi-discover plan consolidates them.)

set -u

TYPES='_smb._tcp|_afpovertcp._tcp|_sftp-ssh._tcp|_webdav._tcp|_webdavs._tcp'

tmpfile=$(mktemp); trap 'rm -f "$tmpfile"; printf "\033[?25h"' EXIT

spin_until() {
    local pid=$1 label=$2
    local chars=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
    local n=${#chars[@]} i=0
    printf '\033[?25l'
    while kill -0 "$pid" 2>/dev/null; do
        printf '\r\033[36m%s\033[0m %s ' "${chars[i % n]}" "$label"
        i=$((i + 1))
        sleep 0.08
    done
    printf '\r\033[K\033[?25h'
}

url_encode() {
    local s=$1 i c
    for ((i=0; i<${#s}; i++)); do
        c="${s:i:1}"
        case "$c" in
            [a-zA-Z0-9._~-]) printf '%s' "$c" ;;
            *) printf '%%%02X' "'$c" ;;
        esac
    done
}

# Idempotent gio mount: skip if `gio mount -l` already shows the URI,
# otherwise mount synchronously with full tty access (so prompts surface).
ensure_mounted() {
    local uri=$1
    local needle="${uri%/}"
    if gio mount -l 2>/dev/null | grep -qE "(-> $needle$|-> $needle/$)"; then
        return 0
    fi
    printf '\n\033[36m  Authenticating to\033[0m %s\n' "$uri"
    gio mount "$uri"
}

(
    avahi-browse -art --parsable --no-db-lookup 2>/dev/null \
        | awk -F';' -v types="$TYPES" '
            function unescape(s,    out, i, c) {
                out = ""; i = 1
                while (i <= length(s)) {
                    c = substr(s, i, 1)
                    if (c == "\\" && i + 3 <= length(s) && substr(s, i+1, 3) ~ /^[0-9]{3}$/) {
                        out = out sprintf("%c", substr(s, i+1, 3) + 0)
                        i += 4
                    } else {
                        out = out c; i += 1
                    }
                }
                return out
            }
            $1 == "=" && $5 ~ types {
                proto = $5
                sub(/^_/, "", proto); sub(/\._tcp$/, "", proto)
                name = unescape($4)
                host = unescape($7)
                printf "%-32s  %-12s  %s\t%s\t%s\n", name, proto, host, proto, host
            }' \
        | sort -u > "$tmpfile"
) &
spin_until $! "Scanning LAN"
wait
services=$(<"$tmpfile")

if [[ -z "$services" ]]; then
    notify-send -a "Network Browser" "Network Browser" "No LAN file shares advertised"
    exit 0
fi

picked=$(printf '%s\n' "$services" \
    | fzf --delimiter=$'\t' --with-nth=1 \
          --prompt='LAN service: ' --height=40% --reverse) || exit 0

proto=$(printf '%s' "$picked" | cut -f2)
host=$(printf '%s' "$picked" | cut -f3)

case "$proto" in
    smb)
        if ! ensure_mounted "smb://$host/"; then
            notify-send -a "Network Browser" "Network Browser" \
                "Could not authenticate to smb://$host/"
            exit 1
        fi
        shares=$(gio list "smb://$host/" 2>/dev/null | awk '{print $1}') || shares=""
        if [[ -n "$shares" ]]; then
            share=$(printf '%s\n' "$shares" \
                | fzf --prompt="Share on $host: " --height=40% --reverse) || exit 0
            uri="smb://$host/$(url_encode "$share")"
        else
            uri="smb://$host/"
        fi
        ;;
    afpovertcp) uri="afp://$host/" ;;
    sftp-ssh)   uri="sftp://$host/" ;;
    webdav)     uri="dav://$host/" ;;
    webdavs)    uri="davs://$host/" ;;
    *)
        notify-send -a "Network Browser" "Network Browser" "Unknown protocol: $proto"
        exit 1
        ;;
esac

printf %s "$uri" | wl-copy
notify-send -a "Network Browser" "Network Browser" "Copied: $uri — paste in yazi (g a) to mount"
