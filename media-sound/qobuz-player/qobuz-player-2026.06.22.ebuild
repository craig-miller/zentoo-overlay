inherit cargo

UPSTREAM_PV="${PV//./-}"

DESCRIPTION="TUI, web, and connect player for Qobuz hi-fi streaming"
HOMEPAGE="https://github.com/SofusA/qobine"
SRC_URI="
	https://github.com/SofusA/qobine/archive/refs/tags/v${UPSTREAM_PV}.tar.gz -> ${P}.tar.gz
	${CARGO_CRATE_URIS}
"
S="${WORKDIR}/qobine-${UPSTREAM_PV}"

LICENSE="GPL-3"
# Dependent crate licenses
LICENSE+=" Apache-2.0 BSD-2 BSD CDLA-Permissive-2.0 ISC MIT MPL-2.0 UoI-NCSA Unicode-3.0 ZLIB"
SLOT="0"
KEYWORDS="~amd64 ~arm64"
RESTRICT="test"

DEPEND="
	dev-db/sqlite:3=
	dev-libs/glib
	media-libs/alsa-lib
	sys-apps/dbus
"
RDEPEND="${DEPEND}"
BDEPEND="virtual/pkgconfig"

src_configure() {
	export LIBSQLITE3_SYS_USE_PKG_CONFIG=1
	default
}

src_compile() {
	cargo_src_compile --package tui-module
	cargo_src_compile --package web-module
	cargo_src_compile --package connect-module
	cargo_src_compile --package rfid-module
}

src_install() {
	dobin target/release/qobuz-player
	dobin target/release/qobuz-player-web
	dobin target/release/qobuz-player-connect
	dobin target/release/qobuz-player-rfid
	einstalldocs
}
